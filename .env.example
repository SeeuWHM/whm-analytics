# WHM Analytics - Environment Variables
# НЕ КОММИТИТЬ В GIT! Добавить в .gitignore

# ===========================================
# COLLECTOR
# ===========================================

# Matomo URL (без trailing slash)
WHM_MATOMO_URL=https://analytics.webhostmost.com

# Matomo Auth Token (для server-side tracking с IP)
# Получить в Matomo: Settings → Personal → Security → Auth Tokens
WHM_MATOMO_TOKEN=

# Debug mode (не включать на production!)
WHM_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
WHM_LOG_LEVEL=INFO

# ===========================================
# FORWARDERS (будут добавлены позже)
# ===========================================

# Facebook CAPI
# FB_PIXEL_ID=
# FB_ACCESS_TOKEN=

# Google Analytics 4
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=

# Yandex Metrika
# YM_COUNTER_ID=
# YM_AUTH_TOKEN=

# ===========================================
# DATABASE (если понадобится)
# ===========================================

# MATOMO_DB_HOST=localhost
# MATOMO_DB_PORT=3306
# MATOMO_DB_NAME=matomo
# MATOMO_DB_USER=matomo
# MATOMO_DB_PASSWORD=

# ===========================================
# MAXMIND GEOIP
# ===========================================

# License key для автоматического обновления базы
# Получить на https://www.maxmind.com/en/account
# MAXMIND_LICENSE_KEY=
